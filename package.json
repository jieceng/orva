{
  "name": "orvajs",
  "version": "3.1.4",
  "description": "Lightweight Fetch API web framework with typed middleware, RPC, validator, OpenAPI and multi-runtime adapters",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validator": {
      "import": "./dist/validator/index.js",
      "types": "./dist/validator/index.d.ts"
    },
    "./validator/zod": {
      "import": "./dist/validator/zod.js",
      "types": "./dist/validator/zod.d.ts"
    },
    "./openapi": {
      "import": "./dist/openapi/index.js",
      "types": "./dist/openapi/index.d.ts"
    },
    "./openapi/zod": {
      "import": "./dist/openapi/zod.js",
      "types": "./dist/openapi/zod.d.ts"
    },
    "./rpc": {
      "import": "./dist/rpc/index.js",
      "types": "./dist/rpc/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./adapters/node": {
      "import": "./dist/adapters/node.js",
      "types": "./dist/adapters/node.d.ts"
    },
    "./adapters/deno": {
      "import": "./dist/adapters/deno.js",
      "types": "./dist/adapters/deno.d.ts"
    },
    "./adapters/bun": {
      "import": "./dist/adapters/bun.js",
      "types": "./dist/adapters/bun.d.ts"
    },
    "./adapters/aws-lambda": {
      "import": "./dist/adapters/aws-lambda.js",
      "types": "./dist/adapters/aws-lambda.d.ts"
    },
    "./adapters/netlify": {
      "import": "./dist/adapters/netlify.js",
      "types": "./dist/adapters/netlify.d.ts"
    },
    "./adapters/azure": {
      "import": "./dist/adapters/azure.js",
      "types": "./dist/adapters/azure.d.ts"
    },
    "./adapters/cloudflare": {
      "import": "./dist/adapters/cloudflare.js",
      "types": "./dist/adapters/cloudflare.d.ts"
    },
    "./adapters/vercel": {
      "import": "./dist/adapters/vercel.js",
      "types": "./dist/adapters/vercel.d.ts"
    },
    "./middlewares": {
      "import": "./dist/middlewares/index.js",
      "types": "./dist/middlewares/index.d.ts"
    },
    "./middlewares/*": {
      "import": "./dist/middlewares/*.js",
      "types": "./dist/middlewares/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --watch example.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "pack:check": "npm pack --dry-run",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && npm pack --dry-run",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "web",
    "framework",
    "http",
    "router",
    "fetch",
    "orva",
    "orvajs",
    "rpc",
    "openapi",
    "middleware",
    "validator"
  ],
  "author": "jiecheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jieceng/orva.git"
  },
  "homepage": "https://github.com/jieceng/orva#readme",
  "bugs": {
    "url": "https://github.com/jieceng/orva/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.6.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
